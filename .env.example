# ─────────────────────────────────────────────────────────────────
# Agent Frameworks Starter Collection — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to web/.env.local and fill in your keys.
#   cp .env.example web/.env.local
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
# Anthropic API key — powers all agent chat + tool_use execution
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional: Voice Transcription (Whisper) ───────────────────────
# Without this key the app falls back to Web Speech API (Chrome/Edge only).
# Whisper works in all browsers and supports Chinese better.
#
# Option A — OpenAI Whisper
OPENAI_API_KEY=sk-...
#
# Option B — Azure OpenAI Whisper (recommended for China deployments)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=whisper

# ── Optional: Demo mode ───────────────────────────────────────────
# Set to "true" to run the Agent Studio with fully mocked responses
# (no API keys needed — great for UI demos or CI environments).
# NEXT_PUBLIC_DEMO_MODE=false

# ── Optional: kagent / Kubernetes ────────────────────────────────
# Connect the Studio to a real kagent instance for live K8s agents.
# KAGENT_ENDPOINT=http://localhost:8080
# KAGENT_NAMESPACE=default
# KAGENT_API_KEY=

# ── Optional: Azure OpenAI for agent chat ────────────────────────
# Uncomment these to use Azure OpenAI instead of api.anthropic.com
# AZURE_ANTHROPIC_ENDPOINT=https://...
