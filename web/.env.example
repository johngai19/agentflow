# ─── OpsAgent Backend URLs ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your actual values.

# Workflow Engine (opsagent-platform/platform/workflow-engine)
# Docker: localhost:8010, K8s: http://workflow-engine.opsagent.svc.cluster.local
NEXT_PUBLIC_WORKFLOW_ENGINE_URL=http://localhost:8010

# Lark Approval Bridge (opsagent-platform/platform/lark-approval-bridge)
# Docker: localhost:8011
NEXT_PUBLIC_LARK_APPROVAL_BRIDGE_URL=http://localhost:8011

# Credential Broker (opsagent-platform/platform/credential-broker)
# Docker: localhost:8012
NEXT_PUBLIC_CREDENTIAL_BROKER_URL=http://localhost:8012

# CMDB Service / Agent Registry (opsagent-platform/platform/cmdb-service)
# Docker: localhost:8013
NEXT_PUBLIC_CMDB_URL=http://localhost:8013

# GitOps Manager (opsagent-platform/platform/gitops-manager)
# Docker: localhost:8014
NEXT_PUBLIC_GITOPS_MANAGER_URL=http://localhost:8014

# ─── Temporal ─────────────────────────────────────────────────────────────────
# Temporal Web UI (for workflow status links)
NEXT_PUBLIC_TEMPORAL_UI_URL=http://localhost:8080
# Temporal gRPC address (used server-side if you run a Temporal worker)
TEMPORAL_ADDRESS=localhost:7233
# Temporal namespace
TEMPORAL_NAMESPACE=opsagent

# ─── Agent Registry (Temporal integration layer) ──────────────────────────────
# The agent_registry endpoint exposed by the temporal_integration layer.
# By default this is the same host as the workflow engine.
NEXT_PUBLIC_AGENT_REGISTRY_URL=http://localhost:8010

# ─── Auth (future) ────────────────────────────────────────────────────────────
# NEXT_PUBLIC_AUTH_ENABLED=false
# AUTH_SECRET=your-secret-here
